# Audio Services Gateway Configuration
PORT=3000
NODE_ENV=development

# API Authentication
# Comma-separated list of valid API keys for service-to-service authentication
API_KEYS=dev-key-1,dev-key-2,dev-key-3

# Service URLs (internal Docker network)
STT_SERVICE_URL=http://stt-service:3005
TTS_SERVICE_URL=http://tts-service:3006

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# STT Service Configuration
STT_MODEL=whisper-small
STT_MODEL_PATH=/models/whisper
STT_MAX_CONCURRENCY=3
STT_MAX_AUDIO_MB=25
STT_MAX_AUDIO_SECONDS=300
STT_SUPPORTED_FORMATS=wav,mp3,m4a,ogg,flac
STT_DEFAULT_LANGUAGE=vi
STT_SAMPLE_RATE_MIN=8000
STT_SAMPLE_RATE_MAX=48000

# TTS Service Configuration
TTS_MODEL=xtts
TTS_MODEL_PATH=/models/tts
TTS_MAX_CONCURRENCY=5
TTS_MAX_TEXT_CHARS=5000
TTS_DEFAULT_VOICE=default
TTS_DEFAULT_SPEED=1.0
TTS_DEFAULT_FORMAT=wav
TTS_TIMEOUT=30000

# Idempotency Configuration
IDEMPOTENCY_TTL=60
IDEMPOTENCY_ENABLED=true

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Service Metadata
SERVICE_VERSION=1.0.0
SERVICE_NAME=audio-services

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# Audio Processing
AUDIO_TEMP_DIR=/tmp/audio
AUDIO_CLEANUP_INTERVAL=3600000
AUDIO_MAX_AGE=7200000
